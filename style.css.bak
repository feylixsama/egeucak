* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: "Segoe UI", Arial, sans-serif;
}

body {
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 18%, rgba(59, 130, 246, 0.28), transparent 20%),
    radial-gradient(circle at 82% 20%, rgba(14, 165, 233, 0.18), transparent 24%),
    radial-gradient(circle at 50% 85%, rgba(99, 102, 241, 0.14), transparent 22%),
    linear-gradient(135deg, #050816 0%, #0a1633 38%, #102a68 72%, #1d4ed8 100%);
  padding: 16px;
  color: #fff;
}

.app {
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
}

/* TOPBAR */
.topbar {
  width: 100%;
  color: white;
  margin-bottom: 14px;
  padding: 0;
  position: relative;
}

.topbar::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 6px;
  transform: translateX(-50%);
  width: 280px;
  height: 60px;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.18), transparent 68%);
  filter: blur(18px);
  pointer-events: none;
}

.topbar-inner {
  width: 100%;
  display: flex;
}

.topbar-inner > div {
  width: 100%;
}

.topbar-center .topbar-inner {
  justify-content: center;
  align-items: center;
  text-align: center;
}

.topbar-center .topbar-inner > div,
.topbar-center #topbar-title,
.topbar-center #topbar-subtitle {
  text-align: center;
}

.topbar-left .topbar-inner {
  justify-content: flex-start;
  align-items: flex-start;
  text-align: left;
}

.topbar-left .topbar-inner > div,
.topbar-left #topbar-title,
.topbar-left #topbar-subtitle {
  text-align: left;
}

.topbar h1,
#topbar-title {
  font-size: 2rem;
  font-weight: 900;
  letter-spacing: 0.3px;
  margin-bottom: 4px;
  color: #f8fbff;
  text-shadow:
    0 10px 28px rgba(0, 0, 0, 0.32),
    0 0 18px rgba(96, 165, 250, 0.16);
}

.topbar p,
#topbar-subtitle {
  font-size: 0.95rem;
  opacity: 0.92;
  color: rgba(255, 255, 255, 0.82);
}

/* ANA KART */
.main-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(7, 15, 34, 0.96), rgba(8, 14, 28, 0.94));
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-radius: 28px;
  padding: 24px;
  box-shadow:
    0 26px 65px rgba(2, 6, 23, 0.50),
    inset 0 1px 0 rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(148, 163, 184, 0.14);
}

.main-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top center, rgba(59, 130, 246, 0.10), transparent 26%),
    radial-gradient(circle at bottom left, rgba(14, 165, 233, 0.08), transparent 24%);
  pointer-events: none;
}

.main-card::after {
  content: "";
  position: absolute;
  inset: -20% -10%;
  background:
    radial-gradient(circle at 20% 30%, rgba(59, 130, 246, 0.10), transparent 20%),
    radial-gradient(circle at 75% 25%, rgba(34, 211, 238, 0.08), transparent 18%),
    radial-gradient(circle at 55% 80%, rgba(99, 102, 241, 0.08), transparent 20%);
  filter: blur(30px);
  opacity: 0.9;
  animation: ambientFloat 12s ease-in-out infinite alternate;
  pointer-events: none;
}

/* ANA MENÜ */
.menu-hero {
  position: relative;
  margin-bottom: 28px;
  text-align: center;
  animation: fadeUp 0.65s ease both;
}

.menu-hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 7px 14px;
  margin-bottom: 14px;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 800;
  letter-spacing: 0.6px;
  text-transform: uppercase;
  color: #dbeafe;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.24), rgba(14, 165, 233, 0.16));
  border: 1px solid rgba(96, 165, 250, 0.22);
  box-shadow:
    0 8px 24px rgba(37, 99, 235, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

.menu-title {
  text-align: center;
  margin-bottom: 0;
}

.menu-title h2 {
  font-size: 2.35rem;
  color: #f8fbff;
  font-weight: 900;
  margin-bottom: 8px;
  letter-spacing: 0.2px;
  text-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
}

.menu-title p {
  color: #94a3b8;
  font-size: 1rem;
  max-width: 760px;
  margin: 0 auto;
  line-height: 1.6;
}

.game-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
  gap: 18px;
}

.game-card {
  position: relative;
  overflow: hidden;
  padding: 22px;
  border-radius: 22px;
  background: linear-gradient(180deg, rgba(15, 27, 54, 0.95), rgba(9, 18, 36, 0.98));
  border: 1px solid rgba(96, 165, 250, 0.16);
  box-shadow:
    0 16px 30px rgba(0, 0, 0, 0.24),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
  display: flex;
  flex-direction: column;
  gap: 14px;
  transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  animation: fadeUp 0.6s ease both;
  isolation: isolate;
}

.game-card:nth-child(1) {
  animation-delay: 0.05s;
}

.game-card:nth-child(2) {
  animation-delay: 0.12s;
}

.game-card:nth-child(3) {
  animation-delay: 0.19s;
}
.game-card:nth-child(4) {
  animation-delay: 0.26s;
}

.game-card:nth-child(5) {
  animation-delay: 0.33s;
}

.game-card:nth-child(6) {
  animation-delay: 0.40s;
}

.game-card::before {
  content: "";
  position: absolute;
  inset: 0;
  padding: 1px;
  border-radius: 22px;
  background: linear-gradient(
    135deg,
    rgba(96, 165, 250, 0.22),
    rgba(34, 211, 238, 0.10),
    rgba(59, 130, 246, 0.18),
    rgba(244, 114, 182, 0.08)
  );
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0.8;
  pointer-events: none;
}

.game-card::after {
  content: "";
  position: absolute;
  top: -80%;
  left: -30%;
  width: 55%;
  height: 220%;
  transform: rotate(18deg);
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.05),
    transparent
  );
  opacity: 0;
  transition: opacity 0.3s ease, left 0.45s ease;
  pointer-events: none;
}

.game-card:hover {
  transform: translateY(-7px);
  border-color: rgba(96, 165, 250, 0.30);
  box-shadow:
    0 24px 42px rgba(0, 0, 0, 0.32),
    0 0 0 1px rgba(59, 130, 246, 0.08) inset,
    0 0 22px rgba(37, 99, 235, 0.14);
}

.game-card:hover::after {
  left: 110%;
  opacity: 1;
}

.card-icon {
  width: 52px;
  height: 52px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.28), rgba(14, 165, 233, 0.18));
  border: 1px solid rgba(96, 165, 250, 0.18);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  position: relative;
  z-index: 1;
}

.game-card h3 {
  position: relative;
  z-index: 1;
  font-size: 1.22rem;
  color: #f8fbff;
  font-weight: 800;
  margin: 0;
}

.game-card p {
  position: relative;
  z-index: 1;
  color: #aebed3;
  line-height: 1.65;
  min-height: 72px;
  font-size: 0.96rem;
  margin: 0;
}

.card-footer {
  position: relative;
  z-index: 1;
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.card-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 800;
  color: #dbeafe;
  background: rgba(15, 23, 42, 0.85);
  border: 1px solid rgba(148, 163, 184, 0.14);
}

.card-aviation {
  border-color: rgba(96, 165, 250, 0.20);
}

.card-plate {
  border-color: rgba(34, 211, 238, 0.16);
}

.card-coming {
  border-color: rgba(244, 114, 182, 0.14);
}

/* ORTAK BUTONLAR */
.game-card button,
.primary-btn,
.secondary-btn,
#player-name-confirm,
.question-limit-btn,
.nav-btn,
.result-actions button {
  border: none;
  padding: 12px 18px;
  border-radius: 14px;
  cursor: pointer;
  font-size: 0.95rem;
  font-weight: 800;
  transition: 0.24s ease;
}

.game-card button,
.primary-btn,
.nav-btn,
.result-actions button:not(.menu-btn) {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 52%, #1e40af 100%);
  color: white;
  box-shadow:
    0 10px 20px rgba(37, 99, 235, 0.25),
    inset 0 1px 0 rgba(255, 255, 255, 0.10);
}

.game-card button:hover,
.primary-btn:hover,
.nav-btn:hover,
.result-actions button:not(.menu-btn):hover {
  transform: translateY(-2px);
  box-shadow:
    0 14px 24px rgba(37, 99, 235, 0.32),
    0 0 16px rgba(59, 130, 246, 0.18);
}

.secondary-btn,
#player-name-confirm,
.question-limit-btn {
  background: linear-gradient(180deg, #1e293b, #111827);
  color: #e5edf8;
  border: 1px solid rgba(148, 163, 184, 0.16);
}

.secondary-btn:hover,
#player-name-confirm:hover,
.question-limit-btn:hover {
  background: linear-gradient(180deg, #263449, #162033);
}

.menu-btn {
  background: #cbd5e1 !important;
  color: #0f172a !important;
  box-shadow: none !important;
  margin-right: auto;
}

.small-menu-btn {
  min-width: 96px;
  padding: 9px 12px;
  font-size: 0.88rem;
}

.nav-btn {
  min-width: 132px;
}

.nav-btn:disabled {
  background: #64748b !important;
  box-shadow: none !important;
  cursor: not-allowed;
  transform: none !important;
}

/* TOOLBAR */
.game-toolbar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.toolbar-badge {
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.18), rgba(14, 165, 233, 0.14));
  color: #dbeafe;
  border: 1px solid rgba(96, 165, 250, 0.18);
  border-radius: 999px;
  padding: 8px 13px;
  font-size: 0.86rem;
  font-weight: 800;
}

/* STATS */
.compact-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  width: 100%;
  margin: 15px 0;
}

.mini-stat {
  text-align: center;
  padding: 14px 10px;
  border-radius: 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.05);
}

.mini-stat span {
  display: block;
  font-size: 0.76rem;
  color: #94a3b8;
  margin-bottom: 5px;
}

.mini-stat strong {
  font-size: 20px;
  color: #eaf2ff;
}

/* PROGRESS */
.progress-area {
  position: relative;
  z-index: 1;
  margin-bottom: 12px;
}

.compact-progress {
  margin-bottom: 12px;
}

.progress-bar {
  width: 100%;
  height: 11px;
  background: rgba(148, 163, 184, 0.22);
  border-radius: 999px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2563eb, #06b6d4);
  border-radius: 999px;
}

/* HARİTA */
.map-card {
  position: relative;
  z-index: 1;
  background: linear-gradient(180deg, rgba(17, 27, 48, 0.84), rgba(11, 19, 34, 0.92));
  border: 1px solid rgba(96, 165, 250, 0.14);
  border-radius: 20px;
  padding: 10px;
  box-shadow: 0 8px 18px rgba(37, 99, 235, 0.08);
  margin-bottom: 10px;
}

.map-card-title {
  text-align: center;
  font-size: 1.02rem;
  font-weight: 800;
  color: #f8fbff;
  margin-bottom: 6px;
}

.svg-map-wrapper {
  position: relative;
  width: 100%;
  overflow: auto;
  background:
    radial-gradient(circle at 18% 20%, rgba(59, 130, 246, 0.20), transparent 18%),
    radial-gradient(circle at 82% 24%, rgba(34, 211, 238, 0.14), transparent 20%),
    radial-gradient(circle at 50% 82%, rgba(99, 102, 241, 0.16), transparent 24%),
    linear-gradient(180deg, #06101f 0%, #0b172b 48%, #0e213d 100%);
  border: 1px solid rgba(148, 163, 184, 0.20);
  border-radius: 18px;
  padding: 14px;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.04),
    inset 0 0 0 1px rgba(59, 130, 246, 0.04),
    0 18px 40px rgba(2, 6, 23, 0.28);
  isolation: isolate;
}

.svg-map-wrapper::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
  background-size: 28px 28px;
  opacity: 0.32;
  pointer-events: none;
  mask-image: radial-gradient(circle at center, black 55%, transparent 100%);
}

.svg-map-wrapper::after {
  content: "";
  position: absolute;
  inset: 10% 14%;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(56, 189, 248, 0.12), transparent 68%);
  filter: blur(30px);
  pointer-events: none;
}

.compact-map-wrapper {
  min-height: 310px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.svg-map-wrapper svg {
  position: relative;
  z-index: 1;
  max-width: 900px;
  width: 100%;
  height: auto;
  display: block;
  margin: 0 auto;
  background: transparent !important;
}

.map-loading {
  padding: 24px;
  text-align: center;
  color: #cbd5e1;
  font-size: 0.94rem;
}

.turkey-map-svg [id^="TR"] {
  fill: #15396f !important;
  stroke: rgba(255, 255, 255, 0.6) !important;
  stroke-width: 1.15 !important;
  transition: fill 0.28s ease, stroke 0.28s ease, filter 0.28s ease, transform 0.28s ease;
  filter: drop-shadow(0 0 2px rgba(255, 255, 255, 0.12));
}

.turkey-map-svg [id^="TR"]:hover {
  fill: #1b4f93 !important;
  stroke: rgba(255, 255, 255, 0.82) !important;
  filter: drop-shadow(0 0 5px rgba(255, 255, 255, 0.18));
}

.turkey-map-svg .active-city {
  fill: #34d6ff !important;
  stroke: #ffffff !important;
  stroke-width: 1.9 !important;
  filter:
    drop-shadow(0 0 10px rgba(52, 214, 255, 0.6))
    drop-shadow(0 0 18px rgba(102, 126, 234, 0.38));
}

.turkey-map-svg .active-city.active-city-pulse {
  animation: activeProvincePulse 1.4s ease-in-out infinite;
  transform-origin: center;
}

@keyframes activeProvincePulse {
  0%, 100% {
    filter:
      drop-shadow(0 0 8px rgba(52, 214, 255, 0.50))
      drop-shadow(0 0 16px rgba(102, 126, 234, 0.30));
  }
  50% {
    filter:
      drop-shadow(0 0 14px rgba(52, 214, 255, 0.82))
      drop-shadow(0 0 24px rgba(102, 126, 234, 0.46));
  }
}

/* SORU KARTI */
.question-card {
  position: relative;
  z-index: 1;
  background: linear-gradient(180deg, rgba(18, 28, 49, 0.85), rgba(10, 18, 34, 0.94));
  border: 1px solid rgba(96, 165, 250, 0.14);
  border-radius: 18px;
  padding: 14px;
  box-shadow: 0 8px 16px rgba(15, 23, 42, 0.10);
}

.question-card h2 {
  text-align: center;
  font-size: 1.2rem;
  margin-bottom: 12px;
  color: #f8fbff;
  font-weight: 800;
  line-height: 1.35;
}

.question-chip {
  display: inline-block;
  background: rgba(37, 99, 235, 0.14);
  color: #dbeafe;
  border: 1px solid rgba(96, 165, 250, 0.18);
  border-radius: 999px;
  padding: 6px 11px;
  font-size: 0.78rem;
  font-weight: 800;
  margin-bottom: 10px;
}

.answers {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.plate-answers {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.answers button {
  border: 1px solid rgba(96, 165, 250, 0.16);
  padding: 12px 14px;
  border-radius: 13px;
  background: linear-gradient(180deg, rgba(18, 29, 52, 0.90), rgba(11, 18, 34, 0.95));
  cursor: pointer;
  text-align: center;
  font-size: 0.96rem;
  font-weight: 800;
  color: #f8fbff;
  transition: 0.2s ease;
  box-shadow: 0 5px 12px rgba(15, 23, 42, 0.08);
  min-height: 50px;
}

.answers button:hover {
  background: linear-gradient(180deg, rgba(30, 41, 59, 0.95), rgba(15, 23, 42, 0.98));
  border-color: #60a5fa;
  transform: translateY(-2px);
}

.answers button.correct {
  background: linear-gradient(180deg, #14532d, #166534);
  border: 2px solid #22c55e;
  color: #dcfce7;
}

.answers button.wrong {
  background: linear-gradient(180deg, #7f1d1d, #991b1b);
  border: 2px solid #ef4444;
  color: #fee2e2;
}

.answers button:disabled {
  cursor: not-allowed;
  opacity: 1;
}

/* NAV */
.nav-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 10px;
  margin-top: 12px;
  flex-wrap: wrap;
}

/* SONUÇ */
.result-box {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 42px 10px;
}

.result-box h2 {
  font-size: 1.9rem;
  color: #f8fbff;
  margin-bottom: 16px;
  font-weight: 800;
}

.result-score {
  font-size: 1.1rem;
  margin-bottom: 10px;
  color: #dbeafe;
}

.result-message {
  font-size: 0.96rem;
  margin-bottom: 20px;
  color: #aebed3;
}

.result-actions {
  display: flex;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
}

/* YAKINDA */
.coming-soon {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 72px 16px;
}

.coming-soon h2 {
  color: #f8fbff;
  margin-bottom: 10px;
  font-size: 1.7rem;
}

.coming-soon p {
  color: #94a3b8;
  margin-bottom: 20px;
  font-size: 0.95rem;
}

/* ANİMASYON */
@keyframes ambientFloat {
  0% {
    transform: translate3d(-1.5%, -1%, 0) scale(1);
  }
  50% {
    transform: translate3d(1.5%, 1%, 0) scale(1.03);
  }
  100% {
    transform: translate3d(0%, 2%, 0) scale(1.01);
  }
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(20px) scale(0.985);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* MOBİL */
@media (max-width: 900px) {
  .compact-stats {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .mini-stat {
    padding: 12px 8px;
  }

  .mini-stat span {
    font-size: 0.68rem;
  }

  .mini-stat strong {
    font-size: 1rem;
  }

  .plate-answers {
    grid-template-columns: 1fr;
  }

  .compact-map-wrapper {
    min-height: 230px;
  }

  .question-card h2 {
    font-size: 1.08rem;
  }
}

@media (max-width: 768px) {
  .topbar h1,
  #topbar-title {
    font-size: 1.6rem;
  }

  .menu-title h2 {
    font-size: 1.85rem;
  }

  .menu-title p {
    font-size: 0.94rem;
  }

  .main-card {
    padding: 18px;
  }

  .game-card {
    padding: 18px;
  }

  .card-footer {
    flex-direction: column;
    align-items: stretch;
  }

  .card-tag {
    width: fit-content;
  }

  .topbar p {
    font-size: 0.82rem;
  }

  .nav-row {
    justify-content: center;
  }

  .game-toolbar {
    justify-content: center;
  }
}
.geo-music-bar {
  position: relative;
  z-index: 1;
  margin-bottom: 12px;
  padding: 12px 14px;
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(20, 30, 54, 0.82), rgba(11, 19, 34, 0.92));
  border: 1px solid rgba(96, 165, 250, 0.14);
  box-shadow: 0 8px 16px rgba(15, 23, 42, 0.10);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.geo-music-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.geo-music-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 32px;
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 800;
  color: #dbeafe;
  background: rgba(37, 99, 235, 0.14);
  border: 1px solid rgba(96, 165, 250, 0.18);
}

.geo-music-info {
  font-size: 0.9rem;
  color: #cbd5e1;
  font-weight: 600;
}

.geo-music-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

@media (max-width: 768px) {
  .geo-music-bar {
    align-items: stretch;
  }

  .geo-music-actions {
    width: 100%;
  }

  .geo-music-actions button {
    flex: 1;
  }
}

.geo-signature {
  text-align: center;
  margin: 8px 0 14px;
  font-size: 1rem;
  font-weight: 800;
  color: #fda4af;
  letter-spacing: 0.6px;
  text-shadow:
    0 0 10px rgba(251, 113, 133, 0.18),
    0 0 18px rgba(244, 114, 182, 0.10);    
}
.game-card:nth-child(4) {
  animation-delay: 0.26s;
}

.game-card:nth-child(5) {
  animation-delay: 0.33s;
}

.game-card:nth-child(6) {
  animation-delay: 0.40s;
}

.game-card:nth-child(7) {
  animation-delay: 0.47s;
}

.game-card:nth-child(8) {
  animation-delay: 0.54s;
}

.game-card:nth-child(9) {
  animation-delay: 0.61s;
}

.game-loading-screen {
  position: relative;
  overflow: hidden;
  min-height: 560px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 20% 20%, rgba(59, 130, 246, 0.18), transparent 22%),
    radial-gradient(circle at 80% 25%, rgba(34, 211, 238, 0.12), transparent 20%),
    radial-gradient(circle at 50% 85%, rgba(99, 102, 241, 0.14), transparent 24%),
    linear-gradient(180deg, rgba(8, 15, 32, 0.96), rgba(7, 14, 28, 0.98));
  border: 1px solid rgba(96, 165, 250, 0.14);
  box-shadow:
    0 20px 50px rgba(2, 6, 23, 0.35),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
  animation: fadeUp 0.45s ease both;
}

.loading-orb {
  position: absolute;
  border-radius: 999px;
  filter: blur(26px);
  opacity: 0.8;
  pointer-events: none;
}

.orb-1 {
  width: 180px;
  height: 180px;
  top: 10%;
  left: 10%;
  background: rgba(37, 99, 235, 0.24);
  animation: floatingOrb 5s ease-in-out infinite alternate;
}

.orb-2 {
  width: 220px;
  height: 220px;
  right: 8%;
  bottom: 10%;
  background: rgba(34, 211, 238, 0.18);
  animation: floatingOrb 6.5s ease-in-out infinite alternate-reverse;
}

.loading-core {
  position: relative;
  z-index: 2;
  width: min(100%, 560px);
  text-align: center;
  padding: 40px 24px;
}

.loading-icon-wrap {
  width: 116px;
  height: 116px;
  margin: 0 auto 20px;
  position: relative;
  display: grid;
  place-items: center;
}

.loading-icon-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2px solid rgba(96, 165, 250, 0.18);
  border-top-color: rgba(96, 165, 250, 0.95);
  border-right-color: rgba(34, 211, 238, 0.95);
  animation: spinRing 1.2s linear infinite;
  box-shadow: 0 0 24px rgba(59, 130, 246, 0.16);
}

.loading-icon {
  width: 82px;
  height: 82px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-size: 2rem;
  color: #f8fbff;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.35), rgba(14, 165, 233, 0.24));
  border: 1px solid rgba(96, 165, 250, 0.22);
  box-shadow:
    0 10px 24px rgba(37, 99, 235, 0.18),
    inset 0 1px 0 rgba(255, 255, 255, 0.08);
  animation: pulseScale 1.8s ease-in-out infinite;
}

.loading-texts h2 {
  font-size: 2rem;
  font-weight: 900;
  color: #f8fbff;
  margin-bottom: 10px;
}

.loading-texts p {
  color: #aebed3;
  font-size: 1rem;
  margin-bottom: 18px;
}

.loading-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 6px 14px;
  margin-bottom: 16px;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 900;
  letter-spacing: 1px;
  color: #dbeafe;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.22), rgba(14, 165, 233, 0.14));
  border: 1px solid rgba(96, 165, 250, 0.2);
}

.loading-bar {
  width: 100%;
  max-width: 380px;
  height: 12px;
  margin: 0 auto 18px;
  border-radius: 999px;
  overflow: hidden;
  background: rgba(148, 163, 184, 0.18);
  box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.22);
}

.loading-bar-fill {
  width: 0%;
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, #2563eb, #06b6d4, #60a5fa);
  box-shadow: 0 0 16px rgba(59, 130, 246, 0.28);
  animation: fillLoadingBar 1.55s ease forwards;
}

.loading-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
}

.loading-dots span {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #93c5fd;
  opacity: 0.35;
  animation: loadingDots 1.2s ease-in-out infinite;
}

.loading-dots span:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dots span:nth-child(3) {
  animation-delay: 0.4s;
}

.deluxe-coming-soon {
  min-height: 520px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  animation: fadeUp 0.45s ease both;
}

.coming-soon-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 36px;
  padding: 7px 16px;
  border-radius: 999px;
  margin: 0 auto 16px;
  font-size: 0.8rem;
  font-weight: 900;
  color: #dbeafe;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.24), rgba(14, 165, 233, 0.16));
  border: 1px solid rgba(96, 165, 250, 0.2);
}

@keyframes spinRing {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes pulseScale {
  0% {
    transform: scale(1);
    box-shadow:
      0 10px 24px rgba(37, 99, 235, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  50% {
    transform: scale(1.07);
    box-shadow:
      0 14px 28px rgba(37, 99, 235, 0.24),
      0 0 18px rgba(34, 211, 238, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  100% {
    transform: scale(1);
    box-shadow:
      0 10px 24px rgba(37, 99, 235, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
}

@keyframes fillLoadingBar {
  from {
    width: 0%;
  }
  to {
    width: 100%;
  }
}

@keyframes loadingDots {
  0%, 100% {
    transform: translateY(0);
    opacity: 0.35;
  }
  50% {
    transform: translateY(-6px);
    opacity: 1;
  }
}

@keyframes floatingOrb {
  from {
    transform: translateY(0) translateX(0) scale(1);
  }
  to {
    transform: translateY(-18px) translateX(14px) scale(1.08);
  }
}

@media (max-width: 768px) {
  .game-loading-screen {
    min-height: 460px;
  }

  .loading-texts h2 {
    font-size: 1.6rem;
  }

  .loading-texts p {
    font-size: 0.92rem;
  }

  .loading-core {
    padding: 28px 16px;
  }

  .loading-icon-wrap {
    width: 96px;
    height: 96px;
  }

  .loading-icon {
    width: 68px;
    height: 68px;
    font-size: 1.6rem;
  }
}
.city-title {
  text-align: center;
  font-size: 64px;
  font-weight: 800;
  color: #eaf2ff;
  margin: 10px 0 20px;
  letter-spacing: 1px;
  text-shadow:
    0 0 10px rgba(96,165,250,0.4),
    0 0 20px rgba(37,99,235,0.3);
}

/* Orion skor tablosu ve tek satır istatistik güncellemesi */
.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.leaderboard-trigger {
  width: 52px;
  height: 52px;
  border-radius: 16px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #1e293b, #111827);
  color: #f8fafc;
  border: 1px solid rgba(148, 163, 184, 0.18);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
  cursor: pointer;
  font-size: 1.15rem;
}

.leaderboard-trigger:hover {
  transform: translateY(-2px);
  background: linear-gradient(180deg, #263449, #162033);
}

.single-row-stats {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.single-row-stats .mini-stat {
  min-height: 88px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.high-score-stat em,
.result-stat-pill em {
  display: block;
  margin-top: 4px;
  color: #93c5fd;
  font-size: 0.78rem;
  font-style: normal;
  font-weight: 700;
  word-break: break-word;
}

.result-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  margin: 16px 0 10px;
}

.result-stat-pill {
  padding: 12px 10px;
  border-radius: 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  text-align: center;
}

.result-stat-pill span {
  display: block;
  color: #94a3b8;
  font-size: 0.78rem;
  margin-bottom: 4px;
}

.result-stat-pill strong {
  color: #f8fbff;
  font-size: 1.1rem;
}

.leaderboard-box {
  max-width: 920px;
}

.leaderboard-table-wrap {
  width: 100%;
  overflow-x: auto;
  margin-top: 16px;
}

.leaderboard-table {
  width: 100%;
  border-collapse: collapse;
  background: rgba(15, 23, 42, 0.46);
  border-radius: 16px;
  overflow: hidden;
}

.leaderboard-table th,
.leaderboard-table td {
  padding: 12px 14px;
  text-align: left;
  border-bottom: 1px solid rgba(148, 163, 184, 0.12);
}

.leaderboard-table th {
  color: #cfe4ff;
  font-size: 0.84rem;
}

.leaderboard-table td {
  color: #e5edf8;
}

.leaderboard-empty {
  text-align: center !important;
  color: #94a3b8 !important;
}

.leaderboard-note {
  margin-top: 12px;
  font-size: 0.8rem;
  color: #94a3b8;
}

.music-volume-slider {
  width: 120px;
  accent-color: #60a5fa;
}

.menu-btn {
  margin-right: auto;
}

@media (max-width: 768px) {
  .single-row-stats,
  .result-stats-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .music-volume-slider {
    width: 100%;
    min-width: 0;
  }
}


/* 2026-04 UI and audio fixes */
.single-row-stats {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  align-items: stretch;
}

.single-row-stats .mini-stat {
  min-width: 0;
  min-height: 92px;
}

.single-row-stats .mini-stat strong,
.result-stat-pill strong {
  display: block;
  overflow-wrap: anywhere;
}

.card-head {
  align-items: center;
}

.card-icon,
.leaderboard-trigger {
  width: 54px;
  height: 54px;
}

.flag-frame-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 14px;
}

.flag-frame {
  width: min(100%, 340px);
  height: 210px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.12);
  background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
  box-shadow: 0 10px 24px rgba(0,0,0,0.22);
  padding: 14px;
}

.flag-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  border-radius: 14px;
}

.player-name-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  background: rgba(2, 6, 23, 0.76);
  backdrop-filter: blur(10px);
}

.player-name-dialog {
  width: min(100%, 460px);
  padding: 26px;
  border-radius: 24px;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(8, 15, 29, 0.98));
  border: 1px solid rgba(96, 165, 250, 0.22);
  box-shadow: 0 28px 80px rgba(0,0,0,0.34);
}

.player-name-badge {
  display: inline-flex;
  margin-bottom: 12px;
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 800;
  color: #dbeafe;
  background: rgba(37, 99, 235, 0.16);
  border: 1px solid rgba(96, 165, 250, 0.18);
}

.player-name-dialog h3 {
  margin: 0 0 8px;
  color: #f8fbff;
  font-size: 1.55rem;
}

.player-name-dialog p {
  margin: 0 0 16px;
  color: #9fb2c8;
}

.player-name-dialog input {
  width: 100%;
  height: 54px;
  border-radius: 16px;
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(15, 23, 42, 0.9);
  color: #f8fbff;
  padding: 0 16px;
  font-size: 1rem;
  outline: none;
  margin-bottom: 16px;
}

.player-name-dialog input:focus {
  border-color: rgba(96, 165, 250, 0.5);
  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
}

.player-name-actions {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
  flex-wrap: wrap;
}

.finish-btn {
  background: linear-gradient(135deg, #1d4ed8, #0284c7);
}

.question-limit-dialog {
  width: min(100%, 520px);
}

.question-limit-options {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  margin: 18px 0 10px;
}

.question-limit-btn {
  width: 100%;
  text-align: left;
  padding: 15px 18px;
  border: 1px solid rgba(148, 163, 184, 0.16);
}

.question-limit-actions {
  justify-content: flex-start;
}

.input-error-shake {
  animation: inputShake .4s ease;
}

@keyframes inputShake {
  0%,100% { transform: translateX(0); }
  25% { transform: translateX(-6px); }
  75% { transform: translateX(6px); }
}

@media (max-width: 768px) {
  .single-row-stats {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .player-name-actions > * {
    flex: 1;
  }

  .flag-frame {
    height: 190px;
  }
}

#player-name-confirm {
  background: #ffffff;
  color: #0f172a;
  box-shadow: none;
}

#player-name-confirm:hover {
  background: #f8fafc;
}


/* 2026-04 gameplay nav/result polish */
.nav-row {
  align-items: center;
}

.nav-actions-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.nav-row-finish-only {
  justify-content: flex-end;
}

.skip-btn {
  background: linear-gradient(180deg, #1e293b, #111827);
  color: #e5edf8;
  border: 1px solid rgba(148, 163, 184, 0.16);
  box-shadow: none;
}

.skip-btn:hover {
  background: linear-gradient(180deg, #263449, #162033);
}

.nav-btn:disabled,
button:disabled {
  opacity: 0.42 !important;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: none !important;
}

#player-name-confirm {
  border-radius: 14px;
}

.result-box-enhanced {
  text-align: left;
}

.result-actions-top {
  justify-content: flex-start;
  margin-bottom: 18px;
}

.result-stats-grid-large .result-stat-pill {
  min-height: 108px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.leaderboard-panel {
  margin-top: 18px;
}

.leaderboard-panel h3 {
  margin-bottom: 12px;
  color: #f8fbff;
  font-size: 1.1rem;
}

@media (max-width: 768px) {
  .nav-row {
    flex-direction: column;
    align-items: stretch;
  }

  .nav-actions-right {
    margin-left: 0;
    width: 100%;
    justify-content: stretch;
  }

  .nav-actions-right > * {
    flex: 1;
  }

  .nav-row-finish-only {
    align-items: stretch;
  }
}


.loading-result .loading-core {
  border-color: rgba(250, 204, 21, 0.22);
  box-shadow: 0 28px 70px rgba(15, 23, 42, 0.35), 0 0 0 1px rgba(250, 204, 21, 0.08);
}

.loading-result .loading-badge {
  background: rgba(250, 204, 21, 0.14);
  color: #fde68a;
  border-color: rgba(250, 204, 21, 0.2);
}

.loading-result .loading-icon-wrap {
  box-shadow: 0 0 0 10px rgba(250, 204, 21, 0.06), 0 16px 36px rgba(15, 23, 42, 0.32);
}

.loading-result .loading-icon-ring {
  border-color: rgba(250, 204, 21, 0.32);
  border-top-color: rgba(255,255,255,0.92);
}

.loading-result .loading-bar {
  background: rgba(148, 163, 184, 0.18);
}

.loading-result .loading-bar-fill {
  background: linear-gradient(90deg, #f59e0b, #facc15, #fde68a);
}

.loading-result .loading-dots span {
  background: #fbbf24;
}

.loading-result-aviation .loading-icon {
  filter: drop-shadow(0 0 12px rgba(251, 191, 36, 0.45));
}


/* province map click isolation */
.compact-map-wrapper,
.compact-map-wrapper .turkey-map-svg,
.compact-map-wrapper .turkey-map-svg * {
  pointer-events: none !important;
}

.province-question-card,
.nav-row,
.nav-row * {
  position: relative;
  z-index: 3;
}

.province-result-box {
  max-width: 1100px;
}

.province-result-stats {
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
}

.province-review-section {
  margin-top: 28px;
  text-align: left;
}

.province-review-section h3 {
  margin: 0 0 14px;
}

.province-review-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 14px;
}

.province-review-card {
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.04);
  border-radius: 18px;
  padding: 14px 15px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.18);
}

.province-review-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 10px;
}

.province-review-index,
.province-review-state {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.03em;
}

.province-review-state {
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(255,255,255,0.08);
}

.province-review-city,
.province-review-answer {
  font-size: 14px;
  line-height: 1.45;
}

.province-review-city {
  margin-bottom: 6px;
  font-weight: 700;
}

.province-review-correct {
  border-color: rgba(38, 208, 124, 0.45);
}

.province-review-correct .province-review-state {
  background: rgba(38, 208, 124, 0.18);
}

.province-review-wrong {
  border-color: rgba(255, 92, 92, 0.45);
}

.province-review-wrong .province-review-state {
  background: rgba(255, 92, 92, 0.18);
}

.province-review-skipped {
  border-color: rgba(255, 193, 7, 0.38);
}

.province-review-skipped .province-review-state {
  background: rgba(255, 193, 7, 0.16);
}

.province-review-unanswered {
  border-color: rgba(255,255,255,0.12);
}
