        <button class="secondary-btn" id="geography-music-toggle">♫ Müziği Kapat</button>
        <button class="secondary-btn" id="geography-music-prev">⏮ Önceki</button>
        <button class="secondary-btn" id="geography-music-next">⏭ Sonraki</button>
      </div>
    </div>

<div class="geo-signature">❤️ EVRİM ÖZER ❤️</div>

    ${renderStatsRow(game)}

    <div class="progress-area">
      <div class="progress-bar">
        <div class="progress-fill" style="width:${getQuestionProgressPercent(game)}%"></div>
      </div>
    </div>

    <section class="question-card">
      <div class="question-chip">Coğrafya Testi</div>
      <h2>${q.question}</h2>
      <div class="answers" id="answers-container"></div>
    </section>

    ${renderQuestionNav(game, "Testi Bitir")}
  `;

  const answersContainer = document.getElementById("answers-container");

  q.answers.forEach((answer, index) => {
    const button = document.createElement("button");
    button.textContent = answer;

    if (answered) {
      if (index === q.correct) button.classList.add("correct");
      if (index === selected && index !== q.correct) button.classList.add("wrong");
      button.disabled = true;
    }

    button.addEventListener("click", () => {
      if (isAnsweredValue(game.selectedAnswers[game.currentQuestion])) return;

      game.selectedAnswers[game.currentQuestion] = index;

      if (index === q.correct) {
        playCorrectSound();
        game.score += 10;
      } else {
        playWrongSound();
        game.score -= 5;
      }

      updateHighScore(game);
      renderGeographyGame();
    });

    answersContainer.appendChild(button);
  });

  document.getElementById("back-home").addEventListener("click", renderHome);

  const prevBtn = document.getElementById("prev-btn");
  if (prevBtn) {
    prevBtn.addEventListener("click", () => {
      if (game.currentQuestion > 0) {
        game.currentQuestion--;
        renderGeographyGame();
      }
    });
  }

  const nextBtn = document.getElementById("next-btn");
  if (nextBtn) nextBtn.addEventListener("click", () => handleNextQuestion(game, renderGeographyGame, renderGeographyResult));

  const skipBtn = document.getElementById("skip-btn");
  if (skipBtn) skipBtn.addEventListener("click", () => handleSkipQuestion(game, renderGeographyGame, renderGeographyResult));

  const finishBtn = document.getElementById("finish-btn");
  if (finishBtn) finishBtn.addEventListener("click", (event) => {
    event.preventDefault();
    event.stopPropagation();
    renderGeographyResult();
  });

  bindMusicControls("geography", toggleGeographyMusic, prevGeographyTrack, nextGeographyTrack);

  updateMusicButton();
  updateMusicInfo();
}

function renderGeographyResult() {
  stopGeographyMusic();
  updateHighScore(currentGame);

  const game = currentGame;
  const total = game.questions.length * 10;

  let message = "Coğrafya tekrarına ihtiyacın var.";
  if (game.score === total) message = "Mükemmel sonuç. Coğrafya bilgin çok güçlü.";
  else if (game.score >= total * 0.6) message = "İyi performans. Birkaç tekrar ile daha da iyi olur.";

  appScreen.innerHTML = renderResultSummary("Coğrafya Testi Tamamlandı", game, total, message, "restart-geography");

  document.getElementById("restart-geography").addEventListener("click", startGeographyGame);
  document.getElementById("back-home").addEventListener("click", renderHome);
}

/* -----------------------------
   PLAKA OYUNU
------------------------------ */
async function startPlateGame() {
  const setup = await requestGameSetup(plateData.length);
  if (!setup) {
    renderHome();
    return;
  }
  stopGeographyMusic();
  setTopbar("🗺️ Plaka Bilme Oyunu", "Şehirlerin plaka kodlarını tahmin et", "center");

  const selectedCities = buildQuestionSet(plateData, setup.questionLimit);

  currentGame = {
    type: "plate",
    sourceQuestions: [...plateData],
    questions: selectedCities,
    currentQuestion: 0,
    score: 0,
    selectedAnswers: new Array(selectedCities.length).fill(null),
    optionsCache: {},
    playerName: setup.playerName,
    questionLimit: setup.questionLimit,
    isInfinite: setup.isInfinite,
    highScore: getHighScore("plate")
  };

  renderPlateGame();
}

function renderPlateMap() {
  return `
    <section class="map-card">
            <div class="svg-map-wrapper compact-map-wrapper" id="svg-map-wrapper">
        <div class="map-loading">Harita yükleniyor...</div>
      </div>
    </section>
  `;
}

function loadTurkeyMap(activePlate) {
  const mapWrapper = document.getElementById("svg-map-wrapper");
  if (!mapWrapper) return;

  try {
    mapWrapper.innerHTML = turkeySvgInline;

    const svgElement = mapWrapper.querySelector("svg");
    if (!svgElement) {
      throw new Error("SVG içeriği okunamadı.");
    }

    svgElement.classList.add("turkey-map-svg");
    svgElement.style.pointerEvents = "none";
    svgElement.querySelectorAll("*").forEach(node => {
      node.style.pointerEvents = "none";
    });

    const allCities = svgElement.querySelectorAll("[id^='TR']");
    allCities.forEach(city => {
      city.classList.remove("active-city", "active-city-pulse");
    });

    const targetId = `#TR${activePlate}`;
    const activeCity = svgElement.querySelector(targetId);

    if (activeCity) {
      activeCity.classList.add("active-city", "active-city-pulse");
    } else {
      console.warn("İl bulunamadı:", targetId);
    }
  } catch (error) {
    mapWrapper.innerHTML = `<div class="map-loading">Harita yüklenemedi.</div>`;
    console.error("SVG harita yükleme hatası:", error);
  }
}

function buildPlateOptions(correctPlate) {
  const wrongOptions = shuffleArray(
    plateData.filter(item => item.plate !== correctPlate).map(item => item.plate)
  ).slice(0, 3);

  return shuffleArray([correctPlate, ...wrongOptions]);
}

function renderPlateGame() {
  const game = currentGame;
  const currentItem = game.questions[game.currentQuestion];
  const selected = game.selectedAnswers[game.currentQuestion];
  const answered = isAnsweredValue(selected);

  if (!game.optionsCache[game.currentQuestion]) {
    game.optionsCache[game.currentQuestion] = buildPlateOptions(currentItem.plate);
  }

  const options = game.optionsCache[game.currentQuestion];

  appScreen.innerHTML = `
    <div class="game-toolbar">
      <button class="secondary-btn menu-btn small-menu-btn" id="back-home">← Menü</button>
      <div class="toolbar-badge">🗺️ Plaka Bilme Oyunu</div>
    </div>

    

    ${renderStatsRow(game)}
    <div class="progress-area compact-progress">
    <div class="city-title">
  ${currentItem.city}
</div>
      <div class="progress-bar">
        <div class="progress-fill" style="width:${getQuestionProgressPercent(game)}%"></div>
      </div>
    </div>

    <section class="question-card">
      <div class="question-chip">Harita Sorusu</div>
      <h2>${currentItem.city} ilinin plaka kodu nedir?</h2>
      <div class="answers plate-answers" id="answers-container"></div>
    </section>

    ${renderQuestionNav(game, "Oyunu Bitir")}
  `;

  const answersContainer = document.getElementById("answers-container");

  options.forEach(option => {
    const button = document.createElement("button");
    button.textContent = option;

    if (answered) {
      if (option === currentItem.plate) button.classList.add("correct");
      if (option === selected && option !== currentItem.plate) button.classList.add("wrong");
      button.disabled = true;
    }

    button.addEventListener("click", () => {
      if (isAnsweredValue(game.selectedAnswers[game.currentQuestion])) return;

      game.selectedAnswers[game.currentQuestion] = option;

      if (option === currentItem.plate) {

  playCorrectSound();

  game.score += 10;
      } else {
        playWrongSound();

  game.score -= 5;
} 

      updateHighScore(game);
      renderPlateGame();
    });

    answersContainer.appendChild(button);
  });

  document.getElementById("back-home").addEventListener("click", renderHome);
  const prevBtn = document.getElementById("prev-btn");
  if (prevBtn) {
    prevBtn.addEventListener("click", () => {
      if (game.currentQuestion > 0) {
        game.currentQuestion--;
        renderPlateGame();
      }
    });
  }
  const nextBtn = document.getElementById("next-btn");
  if (nextBtn) nextBtn.addEventListener("click", () => handleNextQuestion(game, renderPlateGame, renderPlateResult));
  const skipBtn = document.getElementById("skip-btn");
  if (skipBtn) skipBtn.addEventListener("click", () => handleSkipQuestion(game, renderPlateGame, renderPlateResult));

  const finishBtn = document.getElementById("finish-btn");
  if (finishBtn) {
    finishBtn.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      renderPlateResult();
    });
  }
}

function renderPlateResult() {
  const game = currentGame;
  updateHighScore(currentGame);
  const total = game.questions.length * 10;

  let message = "Plaka tekrarına ihtiyacın var.";
  if (game.score === total) message = "Mükemmel sonuç. Harita ve plaka eşleştirmen çok güçlü.";
  else if (game.score >= total * 0.6) message = "İyi performans. Biraz daha tekrar ile çok daha iyi olur.";

  appScreen.innerHTML = renderResultSummary("Plaka Oyunu Tamamlandı", game, total, message, "restart-plate");

  document.getElementById("restart-plate").addEventListener("click", startPlateGame);
  document.getElementById("back-home").addEventListener("click", renderHome);
}

/* -----------------------------
   YARDIMCI
------------------------------ */
function shuffleArray(array) {
  const arr = [...array];
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

renderHome();
document.addEventListener("click", (e) => {
  if (e.target.tagName === "BUTTON") {
    clickAudio.currentTime = 0;
    clickAudio.play().catch(() => {});
  }
});