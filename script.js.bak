async function startGeographyGame() {
  const setup = await requestGameSetup(geographyQuestions.length);
  if (!setup) {
    renderHome();
    return;
  }
  setTopbar("🌍 Coğrafya Soruları", "Kıtalar, ülkeler ve genel coğrafya bilgisi", "center");

  const selectedQuestions = buildQuestionSet(geographyQuestions, setup.questionLimit);

  currentGame = {
    type: "geography",
    sourceQuestions: [...geographyQuestions],
    questions: selectedQuestions,
    currentQuestion: 0,
    score: 0,
    selectedAnswers: new Array(selectedQuestions.length).fill(null),
    playerName: setup.playerName,
    questionLimit: setup.questionLimit,
    isInfinite: setup.isInfinite,
    highScore: getHighScore("geography")
  };

  if (!geographyAudio) {
    geographyTrackIndex = 0;
  }

  playGeographyMusic();
  renderGeographyGame();
}

