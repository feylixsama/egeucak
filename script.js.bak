function showAnimatedTransition(icon, title, text, callback, options = {}) {
  const {
    duration = null,
    badge = "YÜKLENİYOR",
    texts = null,
    accentClass = ""
  } = options;

  const dynamicDuration = duration ?? Math.floor(Math.random() * 1200) + 1400;
  const progressDuration = Math.max(dynamicDuration - 120, 600);

  appScreen.innerHTML = `
    <div class="game-loading-screen ${accentClass}">
      <div class="loading-orb orb-1"></div>
      <div class="loading-orb orb-2"></div>

      <div class="loading-core">
        <div class="loading-icon-wrap">
          <div class="loading-icon-ring"></div>
          <div class="loading-icon">${icon}</div>
        </div>

        <div class="loading-texts">
          <div class="loading-badge">${badge}</div>
          <h2>${title}</h2>
          <p id="loading-status-text">${text}</p>
        </div>

        <div class="loading-bar">
          <div class="loading-bar-fill" id="loading-bar-fill"></div>
        </div>

        <div class="loading-dots">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
    </div>
  `;

  const loadingBar = document.getElementById("loading-bar-fill");
  if (loadingBar) {
    loadingBar.style.animation = `fillLoadingBar ${progressDuration}ms ease forwards`;
  }

  const statusText = document.getElementById("loading-status-text");
  const loadingTexts = Array.isArray(texts) && texts.length
    ? texts
    : [
        text,
        "Sistem hazırlanıyor...",
        "Sorular yükleniyor...",
        "Neredeyse hazır..."
      ];

  let textIndex = 0;
  const textInterval = Math.max(Math.floor(dynamicDuration / Math.max(loadingTexts.length, 2)), 350);

  const intervalId = setInterval(() => {
    textIndex++;
    if (statusText && textIndex < loadingTexts.length) {
      statusText.textContent = loadingTexts[textIndex];
    }
  }, textInterval);

  setTimeout(() => {
    clearInterval(intervalId);
    callback();
  }, dynamicDuration);
}

function showGameLoading(icon, title, text, callback, duration = null) {
  showAnimatedTransition(icon, title, text, callback, { duration, badge: "YÜKLENİYOR" });
}

function showAviationResultLoading(callback) {
  showAnimatedTransition("✈", "Havacılık Testi Sonuçları", "Performansın hesaplanıyor...", callback, {
    duration: 1850,
    badge: "SONUÇLAR HAZIRLANIYOR",
    accentClass: "loading-result loading-result-aviation",
    texts: [
      "Performansın hesaplanıyor...",
      "Skor tablosu hazırlanıyor...",
      "Uçuş verileri işleniyor...",
      "Sonuç ekranı açılıyor..."
    ]
  });
}

