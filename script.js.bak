const HIGH_SCORE_KEYS = {
  flag: "quizHighScore_flag",
  aviation: "quizHighScore_aviation",
  geography: "quizHighScore_geography",
  plate: "quizHighScore_plate",
  province: "quizHighScore_province",
  neighborprovince: "quizHighScore_neighborprovince"
};

function getHighScore(gameType) {
  try {
    const key = HIGH_SCORE_KEYS[gameType];
    if (!key) return 0;
    const saved = Number(localStorage.getItem(key));
    return Number.isFinite(saved) && saved > 0 ? saved : 0;
  } catch (error) {
    return 0;
  }
}

function setHighScore(gameType, score) {
  try {
    const key = HIGH_SCORE_KEYS[gameType];
    if (!key) return score;
    const currentHighScore = getHighScore(gameType);
    const nextHighScore = Math.max(currentHighScore, score);
    localStorage.setItem(key, String(nextHighScore));
    return nextHighScore;
  } catch (error) {
    return Math.max(getHighScore(gameType), score);
  }
}

function updateHighScore(game) {
  if (!game) return 0;
  game.highScore = setHighScore(game.type, game.score);
  return game.highScore;
}

const flagData = FLAG_CODES.map(code => ({
  code,
  country: countryNamesTR[code] || code.toUpperCase(),
  flag: `https://flagcdn.com/w320/${code}.png`
}));
/* -----------------------------
   BAYRAK OYUNU
------------------------------ */
function buildFlagOptions(correctCountry) {
  const wrongOptions = shuffleArray(
    flagData.filter(item => item.country !== correctCountry).map(item => item.country)
  ).slice(0, 5);

  return shuffleArray([correctCountry, ...wrongOptions]);
}

async function startFlagGame() {
  const setup = await requestGameSetup(flagData.length);
  if (!setup) {
    renderHome();
    return;
  }
  stopGeographyMusic();
  stopAviationMusic();
  setTopbar("🏳️ Bayrak Bilmece", "Bayraklara bak ve doğru ülkeyi seç", "center");

  const selectedFlags = buildQuestionSet(flagData, setup.questionLimit);

  currentGame = {
    type: "flag",
    sourceQuestions: [...flagData],
    questions: selectedFlags,
    currentQuestion: 0,
    score: 0,
    selectedAnswers: new Array(selectedFlags.length).fill(null),
    optionsCache: {},
    playerName: setup.playerName,
    questionLimit: setup.questionLimit,
    isInfinite: setup.isInfinite,
    highScore: getHighScore("flag")
  };

  renderFlagGame();
}

function renderFlagGame() {
  const game = currentGame;
  const currentItem = game.questions[game.currentQuestion];
  const selected = game.selectedAnswers[game.currentQuestion];
  const answered = isAnsweredValue(selected);

  if (!game.optionsCache[game.currentQuestion]) {
    game.optionsCache[game.currentQuestion] = buildFlagOptions(currentItem.country);
  }

  const options = game.optionsCache[game.currentQuestion];

  appScreen.innerHTML = `
    <div class="game-toolbar">
      <button type="button" class="secondary-btn menu-btn" id="back-home">← Menü</button>
      <div class="toolbar-badge">🏳️ Bayrak Bilmece</div>
    </div>

    ${renderStatsRow(game)}

    <div class="progress-area">
      <div class="progress-bar">
        <div class="progress-fill" style="width:${getQuestionProgressPercent(game)}%"></div>
      </div>
    </div>

    <section class="question-card">
      <div class="flag-frame-wrap">
        <div class="flag-frame">
          <img
            src="${currentItem.flag}"
            alt="${currentItem.country} bayrağı"
            class="flag-image"
          />
        </div>
      </div>

      <h2>Bu bayrak hangi ülkeye aittir?</h2>
      <div class="answers" id="answers-container"></div>
    </section>

    ${renderQuestionNav(game, "Testi Bitir")}
  `;

  const answersContainer = document.getElementById("answers-container");

  options.forEach(option => {
    const button = document.createElement("button");
    button.textContent = option;

    if (answered) {
      if (option === currentItem.country) button.classList.add("correct");
      if (option === selected && option !== currentItem.country) button.classList.add("wrong");
      button.disabled = true;
    }

    button.addEventListener("click", () => {
      if (isAnsweredValue(game.selectedAnswers[game.currentQuestion])) return;

      game.selectedAnswers[game.currentQuestion] = option;

      if (option === currentItem.country) {
        playCorrectSound();
        game.score += 10;
      } else {
        playWrongSound();
        game.score -= 5;
      }

      updateHighScore(game);
      renderFlagGame();
    });

    answersContainer.appendChild(button);
  });

  document.getElementById("back-home").addEventListener("click", renderHome);
  const prevBtn = document.getElementById("prev-btn");
  if (prevBtn) {
    prevBtn.addEventListener("click", () => {
      if (game.currentQuestion > 0) {
        game.currentQuestion--;
        renderFlagGame();
      }
    });
  }
  const nextBtn = document.getElementById("next-btn");
  if (nextBtn) nextBtn.addEventListener("click", () => handleNextQuestion(game, renderFlagGame, renderFlagResult));
  const skipBtn = document.getElementById("skip-btn");
  if (skipBtn) skipBtn.addEventListener("click", () => handleSkipQuestion(game, renderFlagGame, renderFlagResult));
  const finishBtn = document.getElementById("finish-btn");
  if (finishBtn) finishBtn.addEventListener("click", (event) => {
    event.preventDefault();
    event.stopPropagation();
    renderFlagResult();
  });
}

function renderFlagResult() {
  const game = currentGame;
  updateHighScore(currentGame);
  const total = game.questions.length * 10;

  let message = "Bayrak tekrarına biraz daha devam et.";
  if (game.score === total) message = "Mükemmel sonuç. Bayrak bilgin çok güçlü.";
  else if (game.score >= total * 0.6) message = "İyi performans. Birkaç tekrar ile daha da iyi olur.";

  appScreen.innerHTML = renderResultSummary("Bayrak Oyunu Tamamlandı", game, total, message, "restart-flag");

  document.getElementById("restart-flag").addEventListener("click", startFlagGame);
  document.getElementById("back-home").addEventListener("click", renderHome);
}

/* -----------------------------
   HAVACILIK OYUNU
------------------------------ */
async function startAviationGame() {
  const setup = await requestGameSetup(aviationQuestions.length);
  if (!setup) {
    renderHome();
    return;
  }
  stopGeographyMusic();

  setTopbar("✈ Havacılık Testi", "Teknik bilgi ve temel uçuş soruları", "center");

  const selectedQuestions = buildQuestionSet(aviationQuestions, setup.questionLimit);

  currentGame = {
    type: "aviation",
    sourceQuestions: [...aviationQuestions],
    questions: selectedQuestions,
    currentQuestion: 0,
    score: 0,
    selectedAnswers: new Array(selectedQuestions.length).fill(null),
    playerName: setup.playerName,
    questionLimit: setup.questionLimit,
    isInfinite: setup.isInfinite,
    highScore: getHighScore("aviation")
  };

  playAviationMusic();

  renderAviationGame();
}

function renderAviationGame() {
  const game = currentGame;
  const q = game.questions[game.currentQuestion];
  const selected = game.selectedAnswers[game.currentQuestion];
  const answered = isAnsweredValue(selected);

  appScreen.innerHTML = `
    <div class="game-toolbar">
      <button type="button" class="secondary-btn menu-btn" id="back-home">← Menü</button>
      <div class="toolbar-badge">✈ Havacılık Testi</div>
    </div>

    <div class="geo-music-bar">
      <div class="geo-music-left">
        <span class="geo-music-chip">🎵 Arka Plan Müziği</span>
        <span class="geography-music-info" id="aviation-music-info">Çalan: -</span>
      </div>
      <div class="geo-music-actions">
        <input type="range" min="0" max="100" value="75" class="music-volume-slider" id="aviation-music-volume" aria-label="Müzik sesi">
        <button class="secondary-btn" id="aviation-music-toggle">♫ Müziği Kapat</button>
        <button class="secondary-btn" id="aviation-music-prev">⏮ Önceki</button>
        <button class="secondary-btn" id="aviation-music-next">⏭ Sonraki</button>
      </div>
    </div>

    ${renderStatsRow(game)}

    <div class="progress-area">
      <div class="progress-bar">
        <div class="progress-fill" style="width:${getQuestionProgressPercent(game)}%"></div>
      </div>
    </div>

    <section class="question-card">
      <h2>${q.question}</h2>
      <div class="answers" id="answers-container"></div>
    </section>

    ${renderQuestionNav(game, "Testi Bitir")}
  `;

  const answersContainer = document.getElementById("answers-container");

  q.answers.forEach((answer, index) => {
    const button = document.createElement("button");
    button.textContent = answer;

    if (answered) {
      if (index === q.correct) button.classList.add("correct");
      if (index === selected && index !== q.correct) button.classList.add("wrong");
      button.disabled = true;
    }

    button.addEventListener("click", () => {
      if (isAnsweredValue(game.selectedAnswers[game.currentQuestion])) return;

      game.selectedAnswers[game.currentQuestion] = index;

      if (index === q.correct) {
        playCorrectSound();
        game.score += 10;
      } else {
        playWrongSound();
        game.score -= 5;
      }

      updateHighScore(game);
      renderAviationGame();
    });

    answersContainer.appendChild(button);
  });

  document.getElementById("back-home").addEventListener("click", () => {
    stopAviationMusic();
    renderHome();
  });

  const prevBtn = document.getElementById("prev-btn");
  if (prevBtn) {
    prevBtn.addEventListener("click", () => {
      if (game.currentQuestion > 0) {
        game.currentQuestion--;
        renderAviationGame();
      }
    });
  }

  const nextBtn = document.getElementById("next-btn");
  if (nextBtn) nextBtn.addEventListener("click", () => handleNextQuestion(game, renderAviationGame, renderAviationResult));

  const skipBtn = document.getElementById("skip-btn");
  if (skipBtn) skipBtn.addEventListener("click", () => handleSkipQuestion(game, renderAviationGame, renderAviationResult));

  const finishBtn = document.getElementById("finish-btn");
  if (finishBtn) finishBtn.addEventListener("click", (event) => {
    event.preventDefault();
    event.stopPropagation();
    finishAviationGame();
  });

  bindMusicControls("aviation", toggleAviationMusic, prevAviationTrack, nextAviationTrack);

  updateAviationMusicInfo();
}

function renderAviationResult() {
  const game = currentGame;
  if (!game) return;

  updateHighScore(game);
  const total = game.questions.length * 10;

  let message = "Daha fazla pratik yapmalısın.";
  if (game.score === total) message = "Mükemmel performans.";
  else if (game.score >= total * 0.6) message = "İyi performans.";

  stopAviationMusic();

  appScreen.innerHTML = renderResultSummary("Havacılık Testi Tamamlandı", game, total, message, "restart-aviation");

  const restartBtn = document.getElementById("restart-aviation");
  const backHomeBtn = document.getElementById("back-home");

  if (restartBtn) {
    restartBtn.addEventListener("click", () => {
      startAviationGame();
    });
  }

  if (backHomeBtn) {
    backHomeBtn.addEventListener("click", () => {
      stopAviationMusic();
      renderHome();
    });
  }
}

function finishAviationGame() {
  const game = currentGame;
  if (!game || game.type !== "aviation") return;
  renderAviationResult();
}

function finishProvinceGame() {
  const game = currentGame;
  if (!game || game.type !== "province") return;

  try {
    game.finishedAt = Date.now();
    renderProvinceResult();
  } catch (error) {
    console.error("Province result render failed:", error);
    appScreen.innerHTML = renderResultSummary(
      "İl Tahmin Etme Tamamlandı",
      game,
      game.questions.length * 10,
      "Sonuç ekranı yeniden oluşturuldu. Buradan güvenle devam edebilirsin.",
      "restart-province"
    );

    const restartBtn = document.getElementById("restart-province");
    if (restartBtn) restartBtn.addEventListener("click", restartProvinceGame);

    const backBtn = document.getElementById("back-home");
    if (backBtn) backBtn.addEventListener("click", renderHome);
  }
}

function finishNeighborProvinceGame() {
  const game = currentGame;
  if (!game || game.type !== "neighborprovince") return;

  try {
    game.finishedAt = Date.now();
    renderNeighborProvinceResult();
  } catch (error) {
    console.error("Neighbor province result render failed:", error);
    appScreen.innerHTML = renderResultSummary(
      "İl Tahmin Etme Tamamlandı",
      game,
      game.questions.length * 10,
      "Sonuç ekranı yeniden oluşturuldu. Buradan güvenle devam edebilirsin.",
      "restart-neighbor-province"
    );

    const restartBtn = document.getElementById("restart-neighbor-province");
    if (restartBtn) restartBtn.addEventListener("click", restartNeighborProvinceGame);

    const backBtn = document.getElementById("back-home");
    if (backBtn) backBtn.addEventListener("click", renderHome);
  }
}

