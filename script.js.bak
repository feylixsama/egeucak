let currentGame = null;

const LEADERBOARD_KEYS = {
  flag: "quizLeaderboard_flag",
  aviation: "quizLeaderboard_aviation",
  geography: "quizLeaderboard_geography",
  plate: "quizLeaderboard_plate",
